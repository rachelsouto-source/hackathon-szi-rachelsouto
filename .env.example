# ===== Auditor de DD Técnica — variáveis de ambiente =====

# Modo demo (1 = usa exemplos do Jurerê III, sem Drive/Claude). Deixe vazio em produção.
DEMO_MODE=1

# --- Claude API (necessário em produção) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
DD_MAX_TOKENS=8000

# --- Google Drive (Service Account) ---
# Opção A: cole o JSON inteiro da service account nesta variável (recomendado no Coolify)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Opção B: caminho de um arquivo .json montado no container
GOOGLE_SERVICE_ACCOUNT_FILE=
# ID da pasta que LISTA os empreendimentos: "00 - Empreendimentos Estruturados / em Estruturação".
# Cada subpasta é um empreendimento (ex.: "1.43 - [6468] Jurerê Spot III").
# O app ancora na RAIZ de cada empreendimento e navega as subpastas (02 - Projetos/..., 05 - Jurídico...).
# Compartilhe essa pasta com o e-mail da service account.
# Valor real (Jurerê III está aqui dentro):
EMPREENDIMENTOS_FOLDER_ID=1D9y8aKfkGGE13WbGMlw07G8Euu0Pg7fF

# Porta (Coolify costuma injetar)
PORT=8000
